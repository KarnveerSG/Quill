{
  "name": "quill-desktop",
  "version": "0.2.0",
  "description": "Quill IDE — multi-workspace AI terminal desktop",
  "main": "main.js",
  "author": "Quill",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "postinstall": "node scripts/copy-vendor.mjs",
    "build": "electron-builder --win portable",
    "build:dir": "electron-builder --win dir",
    "build:alt": "electron-builder --win dir --config.directories.output=../dist/desktop-build"
  },
  "build": {
    "appId": "app.quill.desktop",
    "productName": "Quill",
    "npmRebuild": false,
    "directories": {
      "output": "../dist/desktop"
    },
    "win": {
      "target": [
        "portable",
        "dir"
      ],
      "artifactName": "Quill-${version}-portable.exe"
    },
    "files": [
      "main.js",
      "preload.js",
      "integrations.js",
      "themes.js",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/node-pty/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "playwright": "^1.61.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "monaco-editor": "^0.52.2",
    "node-pty": "^1.1.0"
  }
}
